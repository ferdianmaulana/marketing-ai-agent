# PostgreSQL
POSTGRES_USER=mktagent
POSTGRES_PASSWORD=change_me
POSTGRES_DB=marketing_agent
DATABASE_URL=postgresql://mktagent:change_me@marketing-db:5432/marketing_agent

# Google APIs
# Gemini: https://aistudio.google.com -> Get API key
GEMINI_API_KEY=your_gemini_api_key_here

# YouTube Data API v3: https://console.cloud.google.com -> Enable YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_api_key_here

# YouTube channel IDs to track (comma-separated)
# Find channel ID: go to YouTube channel -> view page source -> search "channelId"
YOUTUBE_CHANNEL_IDS=CHANNEL_ID_1,CHANNEL_ID_2
